#!/usr/bin/env bash
# input: $1 = commit message 文件路径
# output: 不符合 Conventional Commits 规范则阻断
# pos: 提交信息规范门禁（.githooks 第二批）
set -euo pipefail

MSG_FILE="$1"
first_line="$(head -n1 "$MSG_FILE")"

# 自动放行 merge / revert / fixup / squash
case "$first_line" in
  Merge\ * | Revert\ * | fixup!\ * | squash!\ *) exit 0 ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9_./-]+\))?(!)?: .{1,}'
if printf '%s' "$first_line" | grep -Eq "$pattern"; then
  exit 0
fi

cat >&2 <<'EOF'
[commit-msg] ✗ 提交信息不符合 Conventional Commits：
  <type>(<scope>): <subject>
  type ∈ feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert
  示例：feat(auth): 增加登录失败重试
  （merge/revert/fixup/squash 自动放行）
EOF
exit 1
