{
  "name": "memedaily",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint . --max-warnings=0",
    "lint:complexity": "eslint . --config eslint.complexity.config.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "validate": "tsx scripts/validate-data.ts",
    "validate:news": "tsx scripts/validate-news.ts",
    "check": "npm run validate && npm run validate:news && npm run lint && npm run typecheck && npm test && npm run build",
    "fallback:skipped": "tsx scripts/create-skipped-day.ts",
    "fallback:skipped:news": "tsx scripts/create-skipped-news-day.ts"
  },
  "dependencies": {
    "lucide-react": "^0.561.0",
    "next": "^16.0.10",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.0.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
